{
    "key": "group_milo_faq",
    "title": "Milo — FAQ / Common Questions",
    "fields": [
        {
            "key": "field_milo_faq_items",
            "label": "FAQ Items",
            "name": "milo_faq_items",
            "type": "repeater",
            "instructions": "Add or reorder FAQ questions. Leave empty to use built-in defaults.",
            "min": 0,
            "max": 20,
            "layout": "row",
            "button_label": "Add Question",
            "sub_fields": [
                {
                    "key": "field_milo_faq_question",
                    "label": "Question",
                    "name": "question",
                    "type": "text",
                    "required": 1,
                    "default_value": ""
                },
                {
                    "key": "field_milo_faq_answer",
                    "label": "Answer",
                    "name": "answer",
                    "type": "textarea",
                    "rows": 3,
                    "new_lines": "br",
                    "required": 1,
                    "default_value": ""
                }
            ]
        }
    ],
    "location": [
        [
            {
                "param": "page_type",
                "operator": "==",
                "value": "front_page"
            }
        ]
    ],
    "menu_order": 50,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "show_in_rest": 0
}